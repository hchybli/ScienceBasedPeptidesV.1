# Copy to .env.local and adjust. On Vercel, set these in Project Settings → Environment Variables.

# Postgres (required on Vercel for serverless functions; use Neon pooled URL). Build does not run migrations.
DATABASE_URL=
# After pulling new Prisma migrations, run locally or in CI: npm run migrate:deploy

# Public (embedded in client bundle at build time) — must match your Vercel project’s primary domain (apex or www).
NEXT_PUBLIC_SITE_URL=https://sciencebasedpeptides.com
# Site title / header / footer brand: edit DEFAULT_SITE_DISPLAY_NAME in lib/site.ts (NEXT_PUBLIC_SITE_NAME is not used for display).

# Local development: use http://localhost:3000 for NEXT_PUBLIC_SITE_URL so previews and metadata match your dev server.

NODE_ENV=development

JWT_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=orders@sciencebasedpeptides.com

# Optional overrides (defaults are set in lib/crypto-payment.ts for BTC + shared ERC-20)
WALLET_BTC=
WALLET_USDC=
WALLET_USDT=

ADMIN_EMAIL=admin@sciencebasedpeptides.com
ADMIN_PASSWORD=

CRON_SECRET=
