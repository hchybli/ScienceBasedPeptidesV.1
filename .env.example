# Copy to .env.local and adjust. On Vercel, set these in Project Settings → Environment Variables.

# Postgres (required on Vercel for serverless functions; use Neon pooled URL).
# - Production: point to your Production Neon DB/branch
# - Preview: point to a *separate* Neon DB/branch so migrations/seed can't impact prod
# Build does not run migrations; run: npm run migrate:deploy
DATABASE_URL=
# Optional alternates (only if you can't set DATABASE_URL): POSTGRES_PRISMA_URL / POSTGRES_URL / POSTGRES_URL_NON_POOLING

# Vercel: if the live site still looks “old” after a successful deploy:
# 1) Project → Git → confirm repo PENNDOM/ScienceBasedPeptides and Production Branch = main.
# 2) Settings → General → clear “Root Directory” unless the app lives in a subfolder.
# 3) Settings → Build & Development → Build Command should be empty (use vercel.json) or exactly: prisma generate && next build
# 4) Open https://YOUR_DOMAIN/api/version — “commit” must match the latest GitHub main SHA. If null, you are not on a Vercel build.

# Public (embedded in client bundle at build time) — must match your Vercel project’s primary domain (apex or www).
NEXT_PUBLIC_SITE_URL=https://sciencebasedpeptides.com
# Site title / header / footer brand: edit DEFAULT_SITE_DISPLAY_NAME in lib/site.ts (NEXT_PUBLIC_SITE_NAME is not used for display).

# Local development: use http://localhost:3000 for NEXT_PUBLIC_SITE_URL so previews and metadata match your dev server.

NODE_ENV=development

JWT_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=orders@sciencebasedpeptides.com

# Owner email for /api/admin/marketing-metrics (extra guardrail).
METRICS_OWNER_EMAIL=

# Optional overrides (defaults are set in lib/crypto-payment.ts for BTC + shared ERC-20)
WALLET_BTC=
WALLET_USDC=
WALLET_USDT=

ADMIN_EMAIL=admin@sciencebasedpeptides.com
ADMIN_PASSWORD=

CRON_SECRET=
